  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Dorineco/ClickTroc/issues"
  },
  "homepage": "https://github.com/Dorineco/ClickTroc#readme",
  "dependencies": {
    "concurrently": "^9.2.1",
    "config": "^4.4.1",
    "login": "^0.8.0",
    "mongodb": "^7.1.1",
    "mongoose": "^9.4.1",
    "mongosh": "^2.8.2",
    "stripe": "^22.0.1"
  }
}
